usage() {
    local me
    me=$(basename "$0")
    printf "%b\n" "${BOLD}USAGE${NC}"
    printf "  %s <command> [options]\n\n" "${me}"
    printf "%b\n\n" "${BOLD}COMMANDS${NC}"
    printf "  %bencode%b <input> <o> [codec] [bitrate]\n" "${CYAN}" "${NC}"
    printf "    Encode a single file using the VPU hardware\n\n"
    printf "    codec   : h264 (default), hevc, vp8, vp9\n"
    printf "    bitrate : 2M, 4M (default), 8M, 10M...\n\n"
    printf "    Examples:\n"
    printf "      %s encode video.mkv output.mp4\n" "${me}"
    printf "      %s encode video.mkv output.mp4 hevc 6M\n" "${me}"
    printf "      %s encode video.mkv output h264 4M\n\n" "${me}"
    printf "  %bbatch%b <input_dir> <output_dir> [codec] [bitrate]\n" "${CYAN}" "${NC}"
    printf "    Encode all video files in a directory\n\n"
    printf "    Examples:\n"
    printf "      %s batch ./videos ./encoded\n" "${me}"
    printf "      %s batch ./videos ./encoded hevc 6M\n\n" "${me}"
