if [[ -n "${COLORTERM:-}" ]]; then
    _has_color=true
elif [[ -t 1 ]] && command -v tput &>/dev/null && tput colors &>/dev/null 2>&1; then
    [[ $(tput colors) -ge 8 ]] && _has_color=true
fi

if [[ "${_has_color}" == true ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' NC=''
fi

# Default encoding parameters
DEFAULT_CODEC="h264"
DEFAULT_BITRATE="4M"
DEFAULT_PRESET=""
DEFAULT_PIXFMT="nv12"
DEFAULT_AUDIO_CODEC="aac"
