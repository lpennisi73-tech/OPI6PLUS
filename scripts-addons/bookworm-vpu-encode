# =============================================================================
# MAIN
# =============================================================================

main() {
    banner

    local cmd="${1:-help}"
    shift || true

    case "${cmd}" in
        encode)
            check_requirements
            [[ $# -ge 2 ]] || die "Usage: $(basename "$0") encode <input> <o> [codec] [bitrate]"
            encode_single "$@"
            ;;
        batch)
            check_requirements
            [[ $# -ge 2 ]] || die "Usage: $(basename "$0") batch <input_dir> <output_dir> [codec] [bitrate]"
            batch_encode "$@"
            ;;
        benchmark|bench)
            check_requirements
            benchmark
            ;;
        info)
            info_vpu
            ;;
        check)
            check_requirements
            log_result "All checks passed ‚ÄĒ VPU ready !"
            ;;
        help|--help|-h)
            usage
            ;;
        version|--version|-v)
            printf "bookworm-vpu-encode v%s\n" "${VERSION}"
            ;;
        *)
            log_error "Unknown command: ${cmd}"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
