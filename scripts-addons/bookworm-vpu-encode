info_vpu() {
    printf "%b\n" "${BOLD}VPU Information${NC}"
    echo "‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ"
    echo "  Device     : ${VPU_DEVICE}"
    v4l2-ctl -d "${VPU_DEVICE}" --info 2>/dev/null | grep -E "Driver|Card|Version" | \
        sed 's/^/  /'
    echo ""
    echo "  Supported input formats :"
    v4l2-ctl -d "${VPU_DEVICE}" --list-formats-out 2>/dev/null | \
        grep -E "^\s+\[" | sed 's/^/    /'
    echo ""
    echo "  Supported output codecs :"
    v4l2-ctl -d "${VPU_DEVICE}" --list-formats 2>/dev/null | \
        grep -E "^\s+\[" | sed 's/^/    /'
    echo ""
    echo "  Kernel module :"
    modinfo amvx 2>/dev/null | grep -E "filename|version" | sed 's/^/    /'
    echo ""
    echo "  FFmpeg build :"
    "${FFMPEG}" -version 2>&1 | head -2 | sed 's/^/    /'
    echo ""
}

