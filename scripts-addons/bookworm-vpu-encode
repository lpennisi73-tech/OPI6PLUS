# =============================================================================
# SYSTEM CHECKS
# =============================================================================

check_requirements() {
    log_step "Checking system requirements..."

    # Check ffmpeg-sky1
    if ! command -v "${FFMPEG}" &>/dev/null; then
        die "ffmpeg-sky1 not found. Install media-video/ffmpeg-sky1 from localrepo."
    fi
    local ffver
    ffver=$("${FFMPEG}" -version 2>&1 | head -1 | awk '{print $3}')
    log_info "FFmpeg : ${ffver}"

    # Check VPU device
    if [[ ! -e "${VPU_DEVICE}" ]]; then
        die "VPU device ${VPU_DEVICE} not found. Is the amvx kernel module loaded?"
    fi
    log_info "VPU device : ${VPU_DEVICE} ‚úď"

    # Check permissions
    if [[ ! -r "${VPU_DEVICE}" ]] || [[ ! -w "${VPU_DEVICE}" ]]; then
        log_warn "No access to ${VPU_DEVICE}."
        log_warn "Add your user to the 'video' group: usermod -aG video \$USER"
        die "Permission denied on ${VPU_DEVICE}"
    fi
    log_info "VPU access : OK ‚úď"

    # Check kernel module ‚ÄĒ use multiple methods for robustness
    if ! lsmod | grep -q "amvx" && \
       ! grep -q "^amvx " /proc/modules 2>/dev/null && \
       ! [[ -d /sys/module/amvx ]]; then
        die "amvx kernel module not loaded. Run: modprobe amvx"
    fi
    log_info "Kernel module : amvx ‚úď"

    echo ""
}

# =============================================================================
# CODEC SELECTION
# =============================================================================

# Map codec name to v4l2m2m encoder and file extension
get_codec_info() {
    local codec="$1"
    case "${codec,,}" in
        h264|avc)
            echo "h264_v4l2m2m mp4 H.264/AVC"
            ;;
        hevc|h265)
            echo "hevc_v4l2m2m mp4 HEVC/H.265"
            ;;
        vp8)
            echo "vp8_v4l2m2m webm VP8"
            ;;
        vp9)
            echo "vp9_v4l2m2m webm VP9"
            ;;
        *)
            die "Unsupported codec '${codec}'. Supported: h264, hevc, vp8, vp9"
            ;;
    esac
}

# =============================================================================
# ENCODING FUNCTIONS
# =============================================================================

encode_single() {
    local input="$1"
    local output="$2"
    local codec="${3:-${DEFAULT_CODEC}}"
    local bitrate="${4:-${DEFAULT_BITRATE}}"
    local extra_opts="${5:-}"

    [[ -f "${input}" ]] || die "Input file not found: ${input}"

    local codec_info
    codec_info=$(get_codec_info "${codec}")
    local encoder ext codec_name
    read -r encoder ext codec_name <<< "${codec_info}"

    # Auto-add extension if output has none
    if [[ "${output}" != *"."* ]]; then
        output="${output}.${ext}"
    fi

    log_step "Encoding: ${input}"
    log_info "Codec   : ${codec_name} (${encoder})"
    log_info "Bitrate : ${bitrate}"
    log_info "Output  : ${output}"
    echo ""

    # Get input info ‚ÄĒ duration and audio channels
    local duration
    duration=$("${FFPROBE}" -v quiet -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "${input}" 2>/dev/null || echo "?")
    if [[ "${duration}" != "?" ]]; then
        printf "  Duration : %.2f seconds\n" "${duration}"
    fi

    # Detect audio channels and adapt bitrate accordingly
    # 128k is fine for stereo but catastrophic for 5.1 (~21k/channel)
    local channels audio_bitrate
    channels=$("${FFPROBE}" -v quiet \
        -show_entries stream=channels \
        -select_streams a:0 \
        -of default=noprint_wrappers=1:nokey=1 \
        "${input}" 2>/dev/null | head -1)
    case "${channels}" in
        1) audio_bitrate="96k"  ;;  # mono
        2) audio_bitrate="128k" ;;  # stereo
        6) audio_bitrate="384k" ;;  # 5.1 ‚ÄĒ 64k/channel minimum
        8) audio_bitrate="512k" ;;  # 7.1 ‚ÄĒ 64k/channel minimum
        *) audio_bitrate="${DEFAULT_AUDIO_BITRATE}" ;;
    esac
    log_info "Audio   : ${channels:-?}ch ‚Üí ${audio_bitrate}"

    local start_time
    start_time=$(date +%s%N)

    # Progress file ‚ÄĒ FFmpeg writes stats here, we read them separately
    local progress_file
    progress_file=$(mktemp /tmp/bookworm_progress_XXXXXX)

    # Build FFmpeg command
    # NOTE: -vf format=nv12 is REQUIRED for the CIX Sky1 VPU
    # The MVX driver requires YUV input (NV12), not RGB
    #
    # Audio sync fixes for V4L2 M2M hardware encoder :
    #   -vsync cfr          : force constant framerate ‚ÄĒ prevents PTS drift
    #                         when the VPU returns frames out of order
    #   -af aresample=async=1000 : resample audio to stay in sync with video
    #                         (1000 = max samples/sec compensation)
    #   -max_muxing_queue_size 1024 : prevents muxer stalls when video is
    #                         faster than audio (common with HW encoders)
    "${FFMPEG}" \
        -i "${input}" \
        -vf "format=${DEFAULT_PIXFMT}" \
        -c:v "${encoder}" \
        -b:v "${bitrate}" \
        -vsync cfr \
        -c:a "${DEFAULT_AUDIO_CODEC}" \
        -b:a "${audio_bitrate}" \
        -af "aresample=async=1000" \
        -max_muxing_queue_size 1024 \
        ${extra_opts} \
        -progress "${progress_file}" \
        -nostats \
        -y "${output}" \
        2>/tmp/bookworm_ffmpeg_err.log &

    local ffmpeg_pid=$!

    # Progress display loop ‚ÄĒ reads from -progress file
    # FFmpeg writes key=value pairs : frame=, fps=, speed=, out_time=, etc.
    local frame=0 fps=0 speed=0 out_time="00:00:00"
    local total_frames=0
    if [[ "${duration}" != "?" ]]; then
        # Estimate total frames from duration and input framerate
        local fps_in
        fps_in=$("${FFPROBE}" -v quiet -show_entries stream=r_frame_rate \
            -select_streams v:0 \
            -of default=noprint_wrappers=1:nokey=1 \
            "${input}" 2>/dev/null | head -1)
        # fps_in is often "30000/1001" format ‚ÄĒ evaluate it
        total_frames=$(echo "${fps_in:-30/1} ${duration}" | \
            awk '{split($1,a,"/"); fps=a[1]/a[2]; printf "%d", fps*$2}')
    fi

    printf "\n"
    while kill -0 "${ffmpeg_pid}" 2>/dev/null; do
        if [[ -f "${progress_file}" ]]; then
            frame=$(grep   "^frame="    "${progress_file}" 2>/dev/null | tail -1 | cut -d= -f2 || echo 0)
            fps=$(grep     "^fps="      "${progress_file}" 2>/dev/null | tail -1 | cut -d= -f2 || echo 0)
            speed=$(grep   "^speed="    "${progress_file}" 2>/dev/null | tail -1 | cut -d= -f2 || echo "0x")
            out_time=$(grep "^out_time=" "${progress_file}" 2>/dev/null | tail -1 | cut -d= -f2 || echo "00:00:00")
            out_time="${out_time%%.*}" # remove microseconds

            # Build progress bar if we know total frames
            local bar=""
            if [[ "${total_frames}" -gt 0 ]] 2>/dev/null; then
                local pct=$(( frame * 100 / total_frames ))
                local filled=$(( pct * 30 / 100 ))
                local empty=$(( 30 - filled ))
                bar=$(printf "[%${filled}s%${empty}s] %3d%%" | \
                    tr ' ' '‚Ėą' | sed 's/‚Ėą\( *\)$/\1/')
                # Simpler approach
                bar="["
                for ((i=0; i<filled; i++)); do bar+="‚Ėą"; done
                for ((i=0; i<empty; i++));  do bar+="‚ĖĎ"; done
                bar+="] ${pct}%"
            fi

            printf "\r  %b%s%b  frame=%-6s fps=%-6s speed=%-6s time=%s  " \
                "${CYAN}" "${bar}" "${NC}" \
                "${frame}" "${fps}" "${speed}" "${out_time}"
        fi
        sleep 0.5
    done

    # Wait for FFmpeg to finish and get its exit code
    wait "${ffmpeg_pid}"
    local ffmpeg_ret=$?

    printf "\n"
    rm -f "${progress_file}"

    # Show errors if any
    if [[ -s /tmp/bookworm_ffmpeg_err.log ]]; then
        grep -iE "error|warning|failed" /tmp/bookworm_ffmpeg_err.log | \
            grep -v "^$" | head -5 | \
            while IFS= read -r line; do
                printf "%b\n" "  ${YELLOW}${line}${NC}"
            done
    fi
    rm -f /tmp/bookworm_ffmpeg_err.log

    if [[ ${ffmpeg_ret} -ne 0 ]]; then
        die "FFmpeg failed with exit code ${ffmpeg_ret}"
    fi

    local end_time
    end_time=$(date +%s%N)
    local elapsed=$(( (end_time - start_time) / 1000000 ))
    local elapsed_s
    elapsed_s=$(echo "scale=2; ${elapsed}/1000" | bc)

    if [[ -f "${output}" && -s "${output}" ]]; then
        local size
        size=$(du -sh "${output}" | cut -f1)
        log_result "Done in ${elapsed_s}s ‚ÄĒ Output: ${output} (${size})"
    else
        die "Encoding failed or output file is empty"
    fi
}

batch_encode() {
    local input_dir="$1"
    local output_dir="$2"
    local codec="${3:-${DEFAULT_CODEC}}"
    local bitrate="${4:-${DEFAULT_BITRATE}}"

    [[ -d "${input_dir}" ]] || die "Input directory not found: ${input_dir}"
    mkdir -p "${output_dir}" || die "Cannot create output directory: ${output_dir}"

    local codec_info
    codec_info=$(get_codec_info "${codec}")
    local encoder ext codec_name
    read -r encoder ext codec_name <<< "${codec_info}"

    # Find video files
    local files=()
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "${input_dir}" -maxdepth 1 -type f \
        \( -iname "*.mp4" -o -iname "*.mkv" -o -iname "*.avi" \
           -o -iname "*.mov" -o -iname "*.ts"  -o -iname "*.webm" \
           -o -iname "*.flv" -o -iname "*.wmv" -o -iname "*.m4v" \) \
        -print0)

    if [[ ${#files[@]} -eq 0 ]]; then
        die "No video files found in ${input_dir}"
    fi

    log_info "Found ${#files[@]} file(s) to encode"
    log_info "Codec   : ${codec_name}"
    log_info "Bitrate : ${bitrate}"
    log_info "Output  : ${output_dir}"
    echo ""

    local success=0 failed=0 i=1
    for input in "${files[@]}"; do
        local basename
        basename=$(basename "${input%.*}")
        local output="${output_dir}/${basename}_${codec,,}.${ext}"

        printf "%b\n" "${BOLD}[${i}/${#files[@]}] ${basename}${NC}"
        if encode_single "${input}" "${output}" "${codec}" "${bitrate}"; then
            (( success++ )) || true
        else
            log_error "Failed: ${input}"
            (( failed++ )) || true
        fi
        (( i++ )) || true
        echo ""
    done

    printf "%b\n" "${BOLD}‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź${NC}"
    log_result "Batch complete ‚ÄĒ Success: ${success} | Failed: ${failed}"
}

benchmark() {
    log_step "Running VPU benchmark (1080p 30fps, 10 seconds)..."
    echo ""

    local codecs=("h264" "hevc" "vp8" "vp9")
    local results=()

    for codec in "${codecs[@]}"; do
        local codec_info
        codec_info=$(get_codec_info "${codec}")
        local encoder ext codec_name
        read -r encoder ext codec_name <<< "${codec_info}"

        printf "  Testing %-12s : " "${codec_name}"

        local tmpout
        tmpout=$(mktemp /tmp/bookworm_bench_XXXXXX.${ext})

        local start end elapsed fps speed
        start=$(date +%s%N)

        local bench_output
        bench_output=$("${FFMPEG}" \
            -f lavfi -i "testsrc=duration=10:size=1920x1080:rate=30" \
            -vf "format=${DEFAULT_PIXFMT}" \
            -c:v "${encoder}" -b:v "4M" \
            -y "${tmpout}" 2>&1)

        end=$(date +%s%N)
        elapsed=$(( (end - start) / 1000000 ))

        rm -f "${tmpout}"

        # Extract fps and speed from ffmpeg output
        fps=$(echo "${bench_output}" | grep -oP 'fps=\s*\K[0-9.]+' | tail -1)
        speed=$(echo "${bench_output}" | grep -oP 'speed=\s*\K[0-9.]+' | tail -1)
        local size=$(echo "${bench_output}" | grep -oP 'video:\K[0-9]+KiB' | tail -1)

        if [[ -n "${fps}" ]]; then
            printf "%b\n" "${GREEN}${fps} fps${NC} | ${speed}x realtime | ${size}"
            results+=("${codec_name}|${fps}|${speed}|${size}")
        else
            printf "%b\n" "${RED}FAILED${NC}"
            results+=("${codec_name}|FAILED|FAILED|0")
        fi
    done

